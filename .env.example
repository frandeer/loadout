# Loadout 환경변수 예시 — 복사해서 `.env` 로 만들고 실제 값을 채우세요(.env 는 gitignore 됨).
#   cp .env.example .env

# codex-api 이미지 생성 엔진용 API 키. 비우면 codex-api 카드 생성만 비활성화되고
# (앱의 나머지 기능은 정상). 서버는 process.env 를 우선 사용한다.
CODEX_IMAGE_API_KEY=

# (선택) 서버 포트/바인딩 — 기본 4970 / 127.0.0.1.
# LAN 의 다른 기기에서 접근해야 할 때만 HOST 를 0.0.0.0 으로(무인증이므로 신뢰망에서만).
# PORT=4970
# HOST=127.0.0.1
